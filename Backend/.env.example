PORT=3001

# CORS: comma-separated origins (default: http://localhost:3000). e.g. https://myapp.com,https://www.myapp.com
CORS_ORIGIN=http://localhost:3001

# PostgreSQL (used by Prisma). e.g. postgresql://user:password@localhost:5432/webrtc_demo
DATABASE_URL=postgresql://user:password@localhost:5432/webrtc_demo

# Clerk: webhook signing secret and secret key for API auth (verifyToken in ClerkAuthGuard).
CLERK_WEBHOOK_SIGNING_SECRET=whsec_N4Qpb0T4yCeZgpBcOHls2eWfVDAWe8rk
CLERK_SECRET_KEY=
# Comma-separated frontend origins that may send tokens (must match token azp, e.g. http://localhost:3000)
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Instance id (UUID) stored in profiles.instance_id. Must be a valid UUID v4; if unset or invalid, a default UUID is used.
INSTANCE_ID=Nerokod_2025

# Telnyx API (for phone number service). Optional: TELNYX_BASE_URL, TELNYX_TIMEOUT_MS
TELNYX_API_KEY=
# Required for enableVoiceCall: connection id to assign numbers to
TELNYX_CONNECTION_ID=