generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String   @id // Clerk user id
  email                       String?
  username                    String?
  fullName                    String?   @map("full_name")
  avatarUrl                   String?  @map("avatar_url")
  instanceId                  String?  @map("instance_id") @db.Uuid
  telnyxCredentialConnectionId String? @map("telnyx_credential_connection_id")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  // Account & balance
  accountType          String?   @map("account_type")
  status               String?
  balance              Decimal   @default(0) @db.Decimal(18, 6)
  // Admin-only: wallet and suggested top-up amounts (when accountType = 'admin')
  wallet               Json?     // { network: string, address: string }
  individualRegAmount  Decimal?  @map("individual_reg_amount") @db.Decimal(18, 6)
  teamRegAmount        Decimal?  @map("team_reg_amount") @db.Decimal(18, 6)

  phoneNumbers       PhoneNumber[]
  notifications      Notification[]
  topUpTransactions  TopUpTransaction[]
  userSubscriptions  UserSubscription[]

  @@map("users")
}

model PhoneNumber {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  telnyxNumberId    String?   @map("telnyx_number_id")
  phoneNumber      String    @map("phone_number")
  countryCode      String    @default("") @map("country_code")
  capabilities     Json      @default("[]")
  monthlyCost      Decimal   @default(0) @map("monthly_cost") @db.Decimal(10, 2)
  rawTelnyxData    Json?     @map("raw_telnyx_data")
  rawNumberDetails Json?     @map("raw_number_details")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id               String   @id // basic | pro | business
  name             String   @map("name")
  priceMonthly     Decimal  @map("price_monthly") @db.Decimal(10, 2)
  maxPhoneNumbers  Int      @map("max_phone_numbers")
  durationMonths   Int      @map("duration_months")
  userSubscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  planId    String   @map("plan_id")
  startAt   DateTime @map("start_at")
  endAt     DateTime @map("end_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@map("user_subscriptions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TopUpTransaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  txHash    String   @unique @map("tx_hash")
  amount    Decimal  @db.Decimal(18, 6)
  status    String   @default("pending") // pending | verified | failed — only verified count toward balance
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("top_up_transactions")
}
